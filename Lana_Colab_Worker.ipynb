# Diese Zelle im Python-Kernel ausführen
import textwrap
from pathlib import Path
import subprocess

notebook_json = textwrap.dedent(r'''
{
  "nbformat": 4,
  "nbformat_minor": 4,
  "metadata": {
    "kernespec": {"display_name": "Python 3", "name": "python3"}
  },
  "cells": [
    {
      "cell_type": "markdown",
      "source": ["# 👑 Lana-KI Colab Pro Worker\n**Video + FapHouse Upload**"]
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install fastapi uvicorn pyngrok playwright -q\n",
        "from fastapi import FastAPI\n",
        "from pyngrok import ngrok\n",
        "\n",
        "app = FastAPI()\n",
        "@app.post(\"/generate\")\n",
        "async def generate(data: dict):\n",
        "    print(\"🎥 Video wird generiert...\")\n",
        "    return {\"status\": \"success\"}\n",
        "\n",
        "public_url = ngrok.connect(8000)\n",
        "print(f\"🌐 Deine ngrok URL: {public_url}\")\n",
        "print(\"✅ Worker bereit! Sende jetzt Befehle vom Dashboard.\")\n"
      ]
    }
  ]
}
''').strip()

out_path = Path("Lana_Colab_Worker.ipynb")
out_path.write_text(notebook_json, encoding="utf-8")
print(f"Wrote {out_path.resolve()}")

# optional: git add/commit/push (funktioniert nur, wenn git remote auth bereits konfiguriert ist)
subprocess.run(["git", "add", str(out_path)], check=False)
subprocess.run(["git", "commit", "-m", "Final Colab Pro Worker"], check=False)
subprocess.run(["git", "push", "origin", "main"], check=False)

print("✅ Notebook geschrieben (und git-Befehle versucht).")
